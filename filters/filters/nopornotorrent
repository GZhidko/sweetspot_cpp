#
# Auchan up-filter 
# Performs DNAT HTTP to WiFi proxy, blocks torrents
#
# *** Every single filter must have this loophole to our static content
pass in proto tcp to 194.67.1.117 port eq 80,443
pass out proto tcp from 194.67.1.117 port eq 80,443
# ***
# *** Every upfilter must have blocking to dev Auth service
block in proto tcp to 194.67.1.39
block out proto tcp from 194.67.1.39
# ***
# requested by Beeline RfC 271381/12
block in proto tcp to 194.67.1.38
block out proto tcp from 194.67.1.38
# loophole to startwifi.beeline.ru
pass in proto tcp to 194.67.1.30 port eq 80,443
pass out proto tcp from 194.67.1.30 port eq 80,443
# loophole to cp.beelinewifi.ru
pass in proto tcp to 194.67.1.37 port eq 80,443
pass out proto tcp from 194.67.1.37 port eq 80,443
# loophole to dpi.beelinewifi.ru
pass in proto tcp to 194.154.70.120 port eq 80,443
pass out proto tcp from 194.154.70.120 port eq 80,443
# dnat HTTP to WiFi proxy (transparent port)
dnat in proto tcp to port eq 80,3128,8080 redir to 194.154.70.120 port 702
dnat out proto tcp from 194.154.70.120 port eq 702
# block all other services at proxy
block in proto tcp to 194.154.70.120
# loophole to DNS
pass in proto udp to port eq 53
pass out proto udp from port eq 53
pass in proto tcp to port eq 53
pass out proto tcp from port eq 53
# loophole to certain services
pass in proto tcp to port eq 20,21,22,25,88,110,143,333
pass out proto tcp from port eq 20,21,22,25,88,110,143,333
pass in proto tcp to port eq 443,465,555,587,777,587,993,995
pass out proto tcp from port eq 443,465,555,587,777,587,993,995
pass in proto tcp to port eq 2195,2196,3389,3478,4090,4244,4433,4477
pass out proto tcp from port eq 2195,2196,3389,3478,4090,4244,4433,4477
pass in proto tcp to port eq 5190,5222,5223,5228,5242,6443,7000,8000
pass out proto tcp from port eq 5190,5222,5223,5228,5242,6443,7000,8000
pass in proto tcp to port eq 8443,8446,45395,50318,59234
pass out proto tcp from port eq 8443,8446,45395,50318,59234
#
pass in proto udp to port eq 88,500,3478,4500,4090,4244,5222,5223
pass out proto udp from port eq 88,500,3478,4500,4090,4244,5222,5223
pass in proto udp to port eq 5228,5242,5243,9785,45395,50318,59234
pass out proto udp from port eq 5228,5242,5243,9785,45395,50318,59234
# loophole for IPSec needs (IKE, Kerberos, NAT-T), TeamViewer
pass in proto tcp to port eq 88,1194,5001,5060,5938,9997,65534
pass out proto tcp from port eq 88,1194,5001,5060,5938,9997,65534
pass in proto udp to port eq 88,500,1194,4500,5060,5938,65534
pass out proto udp from port eq 88,500,1194,4500,5060,5938,65534
# loophole for VoIP WhatsApp service
pass in proto tcp to 208.43.122.0/24
pass out proto tcp from 208.43.122.0/24
pass in proto udp to 208.43.122.0/24
pass out proto udp from 208.43.122.0/24
# 
#
# Attempt to block torrents
#
block in
block out
