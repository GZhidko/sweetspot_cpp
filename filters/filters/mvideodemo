#
#  UP&DNfilter for SBRF terminals with certain loopholes
#
# *** Every upfilter must have blocking to dev Auth service
block in proto tcp to 194.67.1.39
block out proto tcp from 194.67.1.39
# ***
# requested by Beeline RfC 271381/12
block in proto tcp to 194.67.1.38
block out proto tcp from 194.67.1.38
# loophole for DNS
pass in proto udp to port eq 53
pass out proto udp from port eq 53
pass in proto tcp to port eq 53
pass out proto tcp from port eq 53
# loophole for icmp
pass in proto icmp
pass out proto icmp
# loopholes only to MVideo whitelist 
pass in proto tcp to 37.143.10.119
pass out proto tcp from 37.143.10.119
pass in proto tcp to 65.52.98.0/24
pass out proto tcp from 65.52.98.0/24
pass in proto tcp to 188.134.82.75
pass out proto tcp from 188.134.82.75
pass in proto tcp to 85.198.80.21
pass out proto tcp from 85.198.80.21
pass in proto tcp to 85.198.65.3
pass out proto tcp from 85.198.65.3
pass in proto tcp to 37.143.10.75
pass out proto tcp from 37.143.10.75
# Anything else should be blocked 
block in
block out
